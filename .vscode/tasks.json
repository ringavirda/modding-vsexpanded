    {
      "label": "launch-prep (smex 1.20)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "provision-dotnet (1.20)",
        "provision-game (1.20)",
        "build-smex (1.20)",
        "stage-mods 1.20 (exlib, ppex, smex)"
      ],
      "problemMatcher": []
    }
  ]
}
