{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Steelmaking Expanded (latest)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "launch-prep (smex)",
      "program": "${workspaceFolder}/.game/1.22/Vintagestory.dll",
      "args": [
        "--tracelog",
        "--dataPath",
        "${workspaceFolder}/.gamedata",
        "--addModPath",
        "${workspaceFolder}/bin/Mods"
      ],
      "cwd": "${workspaceFolder}",
      "env": { "DOTNET_ROOT": "${workspaceFolder}/.dotnet" },
      "stopAtEntry": false,
      "console": "internalConsole",
      "requireExactSource": false
    },
